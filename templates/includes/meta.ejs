<meta charset=UTF-8>
<meta name=viewport content="width=device-width, initial-scale=1">
<% const siteName = 'PolyForm Project' %>
<% const pageTitle = locals.title || (locals.name && locals.version ? `${locals.name} ${locals.version}` : siteName) %>
<% const pageDescription = locals.description || 'Simple, standard, plain-language software licenses.' %>
<meta name=description content="<%= pageDescription %>">
<meta name=theme-color content="#fefefe">
<link rel=icon href=/polyform-favicon.png type=image/png>
<link rel=apple-touch-icon href=/polyform-favicon.png>
<meta property=og:type content=website>
<meta property=og:site_name content="<%= siteName %>">
<meta property=og:title content="<%= pageTitle %>">
<meta property=og:description content="<%= pageDescription %>">
<meta property=og:image content="https://polyformproject.org/polyform-social.png">
<meta property=og:image:secure_url content="https://polyformproject.org/polyform-social.png">
<meta property=og:image:type content=image/png>
<meta property=og:image:width content=1200>
<meta property=og:image:height content=630>
<meta property=og:image:alt content="PolyForm Project logo">
<meta name=twitter:card content=summary_large_image>
<meta name=twitter:title content="<%= pageTitle %>">
<meta name=twitter:description content="<%= pageDescription %>">
<meta name=twitter:image content="https://polyformproject.org/polyform-social.png">
<meta name=twitter:image:alt content="PolyForm Project logo">
