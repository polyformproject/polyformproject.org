<!doctype html>
<html lang=en-US>
<head>
  <%- include('meta') %>
  <title><%= title %></title>
  <%- include('styles') %>
  <%- include('rss') %>
</head>
<body>
  <%- include('header') %>
  <%- include('nav') %>
  <main>
    <h2><%= title %></h2>
    <time class=dateline datetime="<%= date.toISOString() %>"><%= date.toLocaleString(
      'en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></time>
    <%- html %>
  </main>
  <%- include('footer') %>
</body>
</html>
